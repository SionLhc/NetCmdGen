{
  "scene": "core-switch",
  "name": "H3C核心交换机",
  "desc": "H3C厂商核心层配置，含VLAN划分、OSPF Area0、链路聚合、管理安全",
  "vendor": "h3c",
  "config": {
    "basic": {
      "hostname": "H3C-Core-01",
      "password": { "value": "H3cC0r3@26", "encrypted": false },
      "enable_ssh": true,
      "ssh_port": 22,
      "user": { "username": "netadmin", "password": "N3t@dm1n", "level": 15 },
      "enable_ntp": true,
      "ntp": { "servers": [{ "ip": "ntp1.aliyun.com" }, { "ip": "ntp2.aliyun.com" }] },
      "enable_snmp": true,
      "snmp": { "version": "v2c", "community_read": "netcmd-read", "community_write": "netcmd-write" }
    },
    "vlan": {
      "vlans": [
        { "id": 1, "name": "Management" },
        { "id": 10, "name": "Office" },
        { "id": 20, "name": "Finance" },
        { "id": 100, "name": "Server" }
      ],
      "vlanifs": [
        { "vlan_id": 1, "ip_address": "10.1.1.1", "mask": "255.255.255.0" },
        { "vlan_id": 10, "ip_address": "10.1.10.1", "mask": "255.255.255.0" },
        { "vlan_id": 20, "ip_address": "10.1.20.1", "mask": "255.255.255.0" },
        { "vlan_id": 100, "ip_address": "10.1.100.1", "mask": "255.255.255.0" }
      ]
    },
    "routing": {
      "ospf": {
        "process_id": 1,
        "router_id": "10.1.1.1",
        "area_id": "0",
        "networks": [
          { "address": "10.1.1.0", "mask": "0.0.0.255" },
          { "address": "10.1.10.0", "mask": "0.0.0.255" },
          { "address": "10.1.20.0", "mask": "0.0.0.255" },
          { "address": "10.1.100.0", "mask": "0.0.0.255" }
        ]
      }
    },
    "security": {
      "acls": [
        {
          "number": 3001,
          "description": "mgmt-filter",
          "rules": [
            { "action": "permit", "protocol": "tcp", "source": "10.1.1.0", "source_wildcard": "0.0.0.255", "destination": "any", "dest_port": "22" },
            { "action": "deny", "protocol": "tcp", "source": "any", "dest_port": "22" }
          ]
        }
      ]
    },
    "interface": {
      "eth_trunks": [
        {
          "trunk_id": 1,
          "description": "To-H3C-Agg-01",
          "mode": "lacp-static",
          "member_ports": ["Ten-GigabitEthernet1/0/49", "Ten-GigabitEthernet1/0/50"]
        }
      ],
      "lldp": { "enable": true, "interval": 30 }
    }
  }
}
