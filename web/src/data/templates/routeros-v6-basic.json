{
  "scene": "router",
  "name": "RouterOS V6 基础路由器",
  "desc": "MikroTik RouterOS V6 路由器基础配置，含上网NAT、DHCP、防火墙",
  "vendor": "routeros",
  "config": {
    "description": "RouterOS V6 基础路由器",
    "basic": {
      "hostname": "ROS-Gateway",
      "user": { "username": "admin", "password": "Admin@2026" },
      "enable_ssh": true,
      "ssh": { "port": 22 },
      "dns_servers": "8.8.8.8,114.114.114.114",
      "ntp_server": "119.28.183.184"
    },
    "interface": {
      "interfaces": [
        { "name": "ether1", "ip": "203.0.113.10", "mask": "24", "description": "WAN-Uplink" },
        { "name": "ether2", "ip": "192.168.1.1", "mask": "24", "description": "LAN" }
      ]
    },
    "routing": {
      "static_routes": [
        { "dest": "0.0.0.0", "prefix": "0", "gateway": "203.0.113.1", "comment": "默认路由" }
      ]
    },
    "security": {
      "nat": [{ "wan_interface": "ether1" }],
      "filter_rules": [
        { "chain": "input", "action": "accept", "protocol": "tcp", "port": "22" },
        { "chain": "input", "action": "accept", "protocol": "icmp" },
        { "chain": "input", "action": "drop", "protocol": "tcp", "port": "8291" }
      ]
    }
  }
}
