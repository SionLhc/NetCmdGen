{
  "scene": "core-switch",
  "name": "锐捷核心交换机",
  "desc": "锐捷RG-S系列核心层配置，含VLAN划分、OSPF、链路聚合AP模式、MSTP、端口安全",
  "vendor": "ruijie",
  "config": {
    "basic": {
      "hostname": "RG-Core-01",
      "password": { "value": "RGC0r3@26", "encrypted": false },
      "enable_ssh": true,
      "ssh_port": 22,
      "user": { "username": "netadmin", "password": "N3t@dm1n", "level": 15 },
      "enable_ntp": true,
      "ntp": { "servers": [{ "ip": "ntp1.aliyun.com" }] },
      "enable_snmp": true,
      "snmp": { "version": "v2c", "community_read": "ruijie-read", "community_write": "ruijie-write" }
    },
    "vlan": {
      "vlans": [
        { "id": 1, "name": "Management" },
        { "id": 10, "name": "Office" },
        { "id": 20, "name": "Finance" },
        { "id": 100, "name": "Server" }
      ],
      "vlanifs": [
        { "vlan_id": 1, "ip_address": "172.20.1.1", "mask": "255.255.255.0" },
        { "vlan_id": 10, "ip_address": "172.20.10.1", "mask": "255.255.255.0" },
        { "vlan_id": 20, "ip_address": "172.20.20.1", "mask": "255.255.255.0" },
        { "vlan_id": 100, "ip_address": "172.20.100.1", "mask": "255.255.255.0" }
      ]
    },
    "routing": {
      "ospf": {
        "process_id": 1,
        "router_id": "172.20.1.1",
        "area_id": "0",
        "networks": [
          { "address": "172.20.1.0", "mask": "0.0.0.255" },
          { "address": "172.20.10.0", "mask": "0.0.0.255" },
          { "address": "172.20.20.0", "mask": "0.0.0.255" },
          { "address": "172.20.100.0", "mask": "0.0.0.255" }
        ]
      }
    },
    "security": {
      "acls": [
        {
          "number": 100,
          "description": "管理访问限制",
          "rules": [
            { "action": "permit", "protocol": "tcp", "source": "172.20.1.0", "source_wildcard": "0.0.0.255", "destination": "any", "dest_port": "22" }
          ]
        }
      ]
    },
    "interface": {
      "eth_trunks": [
        {
          "trunk_id": 1,
          "description": "To-RG-Agg-01",
          "mode": "src-dst-ip",
          "member_ports": ["GigabitEthernet0/25", "GigabitEthernet0/26"]
        }
      ],
      "lldp": { "enable": true }
    }
  }
}
