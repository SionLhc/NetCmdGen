{
  "scene": "firewall",
  "name": "防火墙基础策略",
  "desc": "安全网关，含接口区域划分、域间策略、NAT转换、IPS策略、VPN基础",
  "vendor": "huawei",
  "config": {
    "basic": {
      "hostname": "FW-01",
      "password": {
        "value": "F1r3wall@2026",
        "encrypted": false
      },
      "enable_ssh": true,
      "ssh_port": 22,
      "user": {
        "username": "netadmin",
        "password": "N3t@dm1n",
        "level": 15
      },
      "enable_ntp": true,
      "ntp": {
        "servers": [
          {
            "ip": "ntp1.aliyun.com"
          }
        ]
      },
      "enable_snmp": true,
      "snmp": {
        "version": "v2c",
        "community_read": "monitor",
        "community_write": "admin123"
      }
    },
    "routing": {
      "static_routes": [
        {
          "mask": "0.0.0.0",
          "dest_network": "0.0.0.0",
          "next_hop": "100.1.1.1"
        },
        {
          "mask": "255.255.0.0",
          "dest_network": "192.168.0.0",
          "next_hop": "172.16.0.1"
        }
      ],
      "ospf": {
        "process_id": 1,
        "router_id": "3.3.3.3",
        "area_id": "0",
        "networks": [
          {
            "area": "0",
            "address": "100.1.1.0",
            "mask": "0.0.0.3"
          }
        ]
      }
    },
    "security": {
      "acls": [
        {
          "number": 3001,
          "description": "Trust→Untrust 策略",
          "rules": [
            {
              "action": "permit",
              "protocol": "tcp",
              "source": "192.168.10.0",
              "dest_port": "80",
              "source_wildcard": "0.0.0.255"
            },
            {
              "action": "permit",
              "protocol": "tcp",
              "source": "192.168.10.0",
              "dest_port": "443",
              "source_wildcard": "0.0.0.255"
            },
            {
              "action": "deny",
              "protocol": "ip",
              "source": "192.168.30.0",
              "source_wildcard": "0.0.0.255"
            }
          ]
        },
        {
          "number": 3002,
          "description": "管理访问控制",
          "rules": [
            {
              "action": "permit",
              "protocol": "tcp",
              "source": "192.168.1.0",
              "dest_port": "22",
              "source_wildcard": "0.0.0.255"
            },
            {
              "action": "permit",
              "protocol": "tcp",
              "source": "192.168.1.0",
              "dest_port": "443",
              "source_wildcard": "0.0.0.255"
            },
            {
              "action": "deny",
              "protocol": "ip",
              "source": "any"
            }
          ]
        }
      ],
      "traffic_filters": [
        {
          "interface": "GigabitEthernet0/0/1",
          "acl_number": 3001,
          "direction": "outbound"
        },
        {
          "interface": "GigabitEthernet0/0/2",
          "acl_number": 3002,
          "direction": "inbound"
        }
      ]
    },
    "interface": {
      "eth_trunks": [],
      "lldp": {
        "enable": false
      },
      "port_isolation": {
        "enable": false
      }
    },
    "service": {
      "dhcp_server": {
        "pools": [
          {
            "name": "trust-pool",
            "network": "192.168.10.0",
            "mask": "255.255.255.0",
            "default_router": "192.168.10.1"
          }
        ]
      }
    }
  }
}